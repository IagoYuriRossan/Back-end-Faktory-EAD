# ──────────────────────────────────────
# EG Faktory EAD — Environment Variables (example)
# Do NOT commit real secrets. Use this file as a template only.
# To create a local `.env`, run: `node scripts/generate-env.js`
# ──────────────────────────────────────

# Database (replace with your local dev DB credentials)
# Example format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/faktory_ead?schema=public"

# JWT
# Generate a strong secret for production. Example generation commands:
#  - OpenSSL: `openssl rand -hex 48`
#  - Node: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
# Keep the value secret and rotate as needed.
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET"
JWT_EXPIRES_IN="1d"

# App
PORT=3000
NODE_ENV=development
